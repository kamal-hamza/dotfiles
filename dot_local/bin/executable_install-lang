#!/usr/bin/env python3
import shlex


# =============================================================================
# install-lang - Cross-platform Language and Framework Installer
# =============================================================================
# Installs development tools using mise and various package managers.
# Supports: mise, brew, yay, pacman, cargo, go install, npm, bun, pip, etc.
#
# Usage:
#   install-lang python                    # Install Python and tools
#   install-lang go rust                   # Install multiple languages
#   install-lang --framework django        # Install framework
#   install-lang --list                    # List available languages
# =============================================================================

import sys
import subprocess
import os
from pathlib import Path
from typing import Dict, List, Set, Any

# Try to setup PYTHONPATH for PyYAML from brew's python-yq if available
if sys.platform == "darwin":
    try:
        result = subprocess.run(
            ["brew", "--prefix", "python-yq"],
            capture_output=True,
            text=True,
            check=False
        )
        if result.returncode == 0:
            python_yq_prefix = result.stdout.strip()
            # Try to find the site-packages directory
            libexec_path = Path(python_yq_prefix) / "libexec" / "lib"
            if libexec_path.exists():
                for python_dir in libexec_path.glob("python*"):
                    site_packages = python_dir / "site-packages"
                    if site_packages.exists():
                        # Add to sys.path directly
                        sys.path.insert(0, str(site_packages))
                        break
    except:
        pass

# Check for PyYAML and provide helpful error if missing
try:
    import yaml
except ImportError:
    print("Error: PyYAML is not installed.", file=sys.stderr)
    print("\nThis script requires PyYAML. To install it:", file=sys.stderr)
    print("\n  Option 1 - Install via system package manager (recommended):", file=sys.stderr)
    print("    macOS:  brew install python-yq", file=sys.stderr)
    print("    Arch:   sudo pacman -S python-pyaml", file=sys.stderr)
    print("    Then run: chezmoi apply", file=sys.stderr)
    print("\n  Option 2 - Install Python with mise:", file=sys.stderr)
    print("    mise use -g python@latest", file=sys.stderr)
    print("    eval \"$(mise activate bash)\"", file=sys.stderr)
    print("    python -m pip install pyyaml", file=sys.stderr)
    sys.exit(1)

# =============================================================================
# Configuration
# =============================================================================

# ANSI color codes
class Colors:
    RED = '\033[0;31m'
    GREEN = '\033[0;32m'
    YELLOW = '\033[1;33m'
    BLUE = '\033[0;34m'
    CYAN = '\033[0;36m'
    NC = '\033[0m'  # No Color

# Find tools.yaml
def find_tools_yaml() -> Path:
    """Locate tools.yaml in expected locations."""
    candidates = [
        Path.home() / ".local/share/chezmoi/.chezmoidata/tools.yaml",
        Path(os.getenv("XDG_DATA_HOME", Path.home() / ".local/share")) / "chezmoi/.chezmoidata/tools.yaml",
    ]
    
    # Try chezmoi source-path
    try:
        result = subprocess.run(
            ["chezmoi", "source-path"],
            capture_output=True,
            text=True,
            check=False
        )
        if result.returncode == 0:
            candidates.insert(0, Path(result.stdout.strip()) / ".chezmoidata/tools.yaml")
    except FileNotFoundError:
        pass
    
    for path in candidates:
        if path.exists():
            return path
    
    print_error("Could not find tools.yaml in any expected location")
    sys.exit(1)

CONFIG_FILE = find_tools_yaml()

# =============================================================================
# Output Functions
# =============================================================================

def print_info(message: str):
    """Print informational message."""
    print(f"{Colors.BLUE}→{Colors.NC} {message}")

def print_success(message: str):
    """Print success message."""
    print(f"{Colors.GREEN}✓{Colors.NC} {message}")

def print_warning(message: str):
    """Print warning message."""
    print(f"{Colors.YELLOW}⚠{Colors.NC} {message}")

def print_error(message: str):
    """Print error message."""
    print(f"{Colors.RED}✗{Colors.NC} {message}", file=sys.stderr)

def print_section(message: str):
    """Print section header."""
    print(f"\n{Colors.CYAN}{'=' * 60}{Colors.NC}")
    print(f"{Colors.CYAN}{message}{Colors.NC}")
    print(f"{Colors.CYAN}{'=' * 60}{Colors.NC}\n")

# =============================================================================
# Utility Functions
# =============================================================================

def command_exists(cmd: str) -> bool:
    """Check if a command exists in PATH."""
    return subprocess.run(
        ["command", "-v", cmd],
        shell=True,
        capture_output=True,
        check=False
    ).returncode == 0

def run_command(cmd_list: List[str], check: bool = True, quiet: bool = False) -> bool:
    """Run a shell command and return success status."""
    if not quiet:
        print(f"  Running: {' '.join(cmd_list)}")
    
    try:
        result = subprocess.run(
            cmd_list,
            check=check,
            capture_output=quiet,
            text=True
        )
        return result.returncode == 0
    except subprocess.CalledProcessError as e:
        if not quiet:
            print_error(f"Failed executing: {' '.join(cmd_list)}")
        return False
    except FileNotFoundError:
        if not quiet:
            print_error(f"Command not found: {cmd_list[0]}")
        return False

def detect_os() -> str:
    """Detect the operating system."""
    if sys.platform == "darwin":
        return "macos"
    elif sys.platform.startswith("linux"):
        if command_exists("pacman"):
            return "arch"
        elif command_exists("apt"):
            return "debian"
        elif command_exists("dnf"):
            return "fedora"
        return "linux"
    return "unknown"

# =============================================================================
# Package Manager Installers
# =============================================================================

def install_system(packages: List[str]) -> bool:
    """Install packages using system package manager (brew, yay, pacman, apt)."""
    os_type = detect_os()
    success = True
    
    for package in packages:
        # Skip if already installed
        if command_exists(package):
            print_success(f"{package} is already installed")
            continue
        
        print_info(f"Installing {package} via system package manager...")
        
        if os_type == "macos":
            if not command_exists("brew"):
                print_error("Homebrew not found. Please install Homebrew first.")
                success = False
                continue
            
            # Try regular package first, then cask
            if not run_command(["brew", "install", package], check=False, quiet=True):
                if not run_command(["brew", "install", "--cask", package], check=False, quiet=True):
                    print_warning(f"Could not install {package} via brew")
                    success = False
                else:
                    print_success(f"Installed {package} (cask)")
            else:
                print_success(f"Installed {package}")
        
        elif os_type == "arch":
            # Try yay first, then pacman
            if command_exists("yay"):
                if run_command(["yay", "-S", "--needed", "--noconfirm", package], check=False):
                    print_success(f"Installed {package}")
                else:
                    print_warning(f"Could not install {package} via yay")
                    success = False
            else:
                if run_command(["sudo", "pacman", "-S", "--needed", "--noconfirm", package], check=False):
                    print_success(f"Installed {package}")
                else:
                    print_warning(f"Could not install {package} via pacman")
                    success = False
        
        elif os_type == "debian":
            run_command(["sudo", "apt-get", "update", "-qq"], quiet=True)
            if run_command(["sudo", "apt-get", "install", "-y", package], check=False):
                print_success(f"Installed {package}")
            else:
                print_warning(f"Could not install {package} via apt")
                success = False
        
        elif os_type == "fedora":
            if run_command(["sudo", "dnf", "install", "-y", package], check=False):
                print_success(f"Installed {package}")
            else:
                print_warning(f"Could not install {package} via dnf")
                success = False
        
        else:
            print_error(f"Unsupported OS: {os_type}")
            success = False
    
    return success

def install_mise(packages: List[str]) -> bool:
    """Install packages using mise (replaces asdf)."""
    if not command_exists("mise"):
        print_error("mise is not installed. Please install it first:")
        print_info("  curl https://mise.run | sh")
        print_info("  Or: brew install mise (macOS) / yay -S mise (Arch)")
        return False
    
    success = True
    for package in packages:
        print_info(f"Installing {package} via mise...")
        if run_command(["mise", "use", "-g", package], check=False):
            print_success(f"Installed {package}")
        else:
            print_warning(f"Could not install {package} via mise")
            success = False
    
    return success

def install_go_install(packages: List[str]) -> bool:
    """Install packages using 'go install'."""
    if not command_exists("go"):
        print_error("Go is not installed. Install it first with: install-lang golang")
        return False
    
    success = True
    for package in packages:
        print_info(f"Installing {package} via go install...")
        # Ensure package has version suffix
        if "@" not in package:
            package = f"{package}@latest"
        
        if run_command(["go", "install", package], check=False):
            print_success(f"Installed {package}")
        else:
            print_warning(f"Could not install {package} via go install")
            success = False
    
    return success

def install_cargo(packages: List[str]) -> bool:
    """Install packages using cargo."""
    if not command_exists("cargo"):
        print_error("Cargo is not installed. Install it first with: install-lang rust")
        return False
    
    success = True
    for package in packages:
        print_info(f"Installing {package} via cargo...")
        if run_command(["cargo", "install", package], check=False):
            print_success(f"Installed {package}")
        else:
            print_warning(f"Could not install {package} via cargo")
            success = False
    
    return success

def install_npm_global(packages: List[str]) -> bool:
    """Install packages using npm globally."""
    if not command_exists("npm"):
        print_error("npm is not installed. Install it first with: install-lang node")
        return False
    
    success = True
    cmd = ["npm", "install", "-g"] + packages
    print_info(f"Installing {len(packages)} package(s) via npm...")
    if run_command(cmd, check=False):
        print_success(f"Installed {len(packages)} npm package(s)")
    else:
        print_warning("Some npm packages failed to install")
        success = False
    
    return success

def install_bun_global(packages: List[str]) -> bool:
    """Install packages using bun globally."""
    if not command_exists("bun"):
        print_error("Bun is not installed. Install it first with: install-lang bun")
        return False
    
    success = True
    for package in packages:
        print_info(f"Installing {package} via bun...")
        if run_command(["bun", "add", "-g", package], check=False):
            print_success(f"Installed {package}")
        else:
            print_warning(f"Could not install {package} via bun")
            success = False
    
    return success

def install_uv_tool(packages: List[str]) -> bool:
    """Install Python tools using uv."""
    if not command_exists("uv"):
        print_error("uv is not installed. Installing it now...")
        if detect_os() == "macos":
            run_command(["brew", "install", "uv"])
        elif detect_os() == "arch":
            run_command(["yay", "-S", "uv"])
        else:
            run_command(["curl", "-LsSf", "https://astral.sh/uv/install.sh", "|", "sh"])
    
    success = True
    for package in packages:
        print_info(f"Installing {package} via uv tool...")
        if run_command(["uv", "tool", "install", package], check=False):
            print_success(f"Installed {package}")
        else:
            print_warning(f"Could not install {package} via uv")
            success = False
    
    return success

def install_gem(packages: List[str]) -> bool:
    """Install Ruby gems."""
    if not command_exists("gem"):
        print_error("gem is not installed. Install it first with: install-lang ruby")
        return False
    
    success = True
    for package in packages:
        print_info(f"Installing {package} via gem...")
        if run_command(["gem", "install", package], check=False):
            print_success(f"Installed {package}")
        else:
            print_warning(f"Could not install {package} via gem")
            success = False
    
    return success

def install_composer_global(packages: List[str]) -> bool:
    """Install PHP packages using composer globally."""
    if not command_exists("composer"):
        print_error("Composer is not installed. Install it first with: install-lang php")
        return False
    
    success = True
    for package in packages:
        print_info(f"Installing {package} via composer...")
        if run_command(["composer", "global", "require", package], check=False):
            print_success(f"Installed {package}")
        else:
            print_warning(f"Could not install {package} via composer")
            success = False
    
    return success

def install_dotnet_tool(packages: List[str]) -> bool:
    """Install .NET tools."""
    if not command_exists("dotnet"):
        print_error("dotnet is not installed. Install it first with: install-lang csharp")
        return False
    
    success = True
    for package in packages:
        print_info(f"Installing {package} via dotnet tool...")
        if run_command(["dotnet", "tool", "install", "-g", package], check=False):
            print_success(f"Installed {package}")
        else:
            print_warning(f"Could not install {package} via dotnet tool")
            success = False
    
    return success

def install_mix(packages: List[str]) -> bool:
    """Install Elixir packages using mix."""
    if not command_exists("mix"):
        print_error("mix is not installed. Install it first with: install-lang elixir")
        return False
    
    success = True
    for package in packages:
        print_info(f"Installing {package} via mix...")
        if run_command(["mix", "escript.install", "hex", package], check=False):
            print_success(f"Installed {package}")
        else:
            print_warning(f"Could not install {package} via mix")
            success = False
    
    return success

def install_custom_cmd(commands: List[str]) -> bool:
    """Run custom shell commands."""
    success = True
    for cmd in commands:
        print_info(f"Running custom command: {cmd}")
        if run_command(shlex.split(cmd), check=False):
            print_success(f"Executed: {cmd}")
        else:
            print_warning(f"Failed: {cmd}")
            success = False
    
    return success

# Map installer names to functions
INSTALLERS = {
    "system": install_system,
    "mise": install_mise,
    "go_install": install_go_install,
    "cargo": install_cargo,
    "npm_global": install_npm_global,
    "bun_global": install_bun_global,
    "uv_tool": install_uv_tool,
    "gem": install_gem,
    "composer_global": install_composer_global,
    "dotnet_tool": install_dotnet_tool,
    "mix": install_mix,
    "custom_cmd": install_custom_cmd,
}

# =============================================================================
# Core Installation Logic
# =============================================================================

def load_config() -> Dict[str, Any]:
    """Load and parse tools.yaml configuration."""
    try:
        with open(CONFIG_FILE, "r") as file:
            return yaml.safe_load(file)
    except FileNotFoundError:
        print_error(f"Configuration file not found: {CONFIG_FILE}")
        sys.exit(1)
    except yaml.YAMLError as e:
        print_error(f"Error parsing YAML: {e}")
        sys.exit(1)

def install_target(
    target: str,
    config: Dict[str, Any],
    installed_set: Set[str],
    is_framework: bool = False
) -> bool:
    """Install a language or framework with its dependencies."""
    # Skip if already installed in this run
    if target in installed_set:
        return True
    
    # Determine which section to use
    section = "frameworks" if is_framework else "languages"
    
    # Check if target exists
    if section not in config or target not in config[section]:
        print_error(f"'{target}' not found in {section} section of {CONFIG_FILE}")
        return False
    
    data = config[section][target]
    
    # Resolve dependencies first
    if "depends_on" in data:
        for dep in data["depends_on"]:
            print_info(f"[{target}] requires '{dep}'. Resolving dependency...")
            if not install_target(dep, config, installed_set, is_framework=False):
                print_error(f"Failed to install dependency '{dep}' for '{target}'")
                return False
    
    print_section(f"Installing {section[:-1]}: {target}")
    
    # Process installation steps
    steps = data.get("steps", [])
    if not steps:
        print_warning(f"No installation steps defined for '{target}'")
        installed_set.add(target)
        return True
    
    overall_success = True
    for step in steps:
        for installer_name, packages in step.items():
            if installer_name in INSTALLERS:
                if not INSTALLERS[installer_name](packages):
                    overall_success = False
            else:
                print_error(f"Unknown installer type: {installer_name}")
                overall_success = False
    
    if overall_success:
        print_success(f"Successfully configured '{target}'")
        installed_set.add(target)
    else:
        print_warning(f"'{target}' installation completed with some errors")
    
    return overall_success

# =============================================================================
# CLI Interface
# =============================================================================

def list_available_targets(config: Dict[str, Any]):
    """List all available languages and frameworks."""
    print_section("Available Languages")
    if "languages" in config:
        for lang in sorted(config["languages"].keys()):
            print(f"  • {lang}")
    
    print_section("Available Frameworks")
    if "frameworks" in config:
        for framework in sorted(config["frameworks"].keys()):
            print(f"  • {framework}")

def show_usage():
    """Display usage information."""
    print(f"""
{Colors.CYAN}install-lang{Colors.NC} - Cross-platform Language and Framework Installer

{Colors.YELLOW}USAGE:{Colors.NC}
    install-lang <target> [target...]     Install language(s) or framework(s)
    install-lang --list                   List available targets
    install-lang --help                   Show this help message

{Colors.YELLOW}EXAMPLES:{Colors.NC}
    install-lang python                   Install Python and its tools
    install-lang go rust                  Install multiple languages
    install-lang typescript django        Install TypeScript and Django
    install-lang --list                   Show all available languages/frameworks

{Colors.YELLOW}FEATURES:{Colors.NC}
    • Uses mise instead of asdf for version management
    • Supports multiple package managers (cargo, go, npm, bun, etc.)
    • Automatic dependency resolution
    • Cross-platform (macOS, Arch Linux, Debian, Fedora)
    • Step-based installation for precise control

{Colors.YELLOW}CONFIGURATION:{Colors.NC}
    Config file: {CONFIG_FILE}
    """)

def main():
    """Main entry point."""
    # Parse arguments
    if len(sys.argv) < 2 or "--help" in sys.argv or "-h" in sys.argv:
        show_usage()
        sys.exit(0)
    
    config = load_config()
    
    if "--list" in sys.argv or "-l" in sys.argv:
        list_available_targets(config)
        sys.exit(0)
    
    # Get targets from command line
    targets = [arg for arg in sys.argv[1:] if not arg.startswith("-")]
    
    if not targets:
        print_error("No targets specified")
        show_usage()
        sys.exit(1)
    
    # Install all targets
    installed_set = set()
    all_success = True
    
    for target in targets:
        # Check if it's a language or framework
        is_framework = (
            "frameworks" in config and 
            target in config["frameworks"]
        )
        
        if not install_target(target, config, installed_set, is_framework):
            all_success = False
    
    # Final summary
    print_section("Installation Summary")
    print_info(f"Processed {len(targets)} target(s)")
    print_info(f"Successfully configured: {len(installed_set)} item(s)")
    
    if all_success:
        print_success("All installations completed successfully!")
        sys.exit(0)
    else:
        print_warning("Some installations had errors. Check output above.")
        sys.exit(1)

if __name__ == "__main__":
    main()