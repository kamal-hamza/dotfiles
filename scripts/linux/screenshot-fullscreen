#!/usr/bin/env bash

# =============================================================================
# Screenshot - Full Screen with Annotation
# =============================================================================
# Captures the entire screen and opens it in satty for annotation
# before saving to ~/Pictures/Screenshots/
#
# Usage:
#   screenshot-fullscreen
#
# Requirements:
#   - grim (image capture)
#   - satty (annotation tool)
#   - wl-copy (Wayland clipboard)
# =============================================================================

set -e

# Define the directory and ensure it exists
SAVE_DIR="$HOME/Pictures/Screenshots"
mkdir -p "$SAVE_DIR"

# Execute the screenshot pipeline
# wl-copy is used for clipboard operations on Wayland
grim - | satty --filename - --copy-command wl-copy --output-filename "$SAVE_DIR/screenshot-$(date +%Y%m%d-%H%M%S).png"
