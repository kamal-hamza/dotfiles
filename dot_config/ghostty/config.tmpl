# ===================================================================
# General Appearance 
# ===================================================================

{{- $scheme := .active_scheme | default "soft-focus-dark" }}
# Load Base16 theme generated by flavours
theme = base16-{{ $scheme }}

font-family = {{ .font_family }}
font-size = {{ .font_sizes.wezterm }}

# Cursor configuration
cursor-style = block
cursor-style-blink = false

# Window padding
window-padding-x = 10
window-padding-y = 10

# Window decorations
window-decoration = true

# Ghostty hides the tab bar automatically if there is only one tab.
# Note: Ghostty does not currently support moving the tab bar to the bottom natively.

# Dim inactive panes
unfocused-split-opacity = 0.5

# ===================================================================
# OS-Specific Appearance
# ===================================================================

{{ if eq .chezmoi.os "darwin" }}
background-blur-radius = 15
# Ghostty requires opacity to be slightly lowered for background blur to apply
background-opacity = 0.9 
{{ end }}

{{ if eq .chezmoi.os "windows" }}
background-blur-radius = 20
background-opacity = 0.9
{{ end }}

# ===================================================================
# Multiplexer Keybindings (Windows Only)
# ===================================================================

{{ if eq .chezmoi.os "windows" }}

# Pane splitting (using ctrl+s as a leader via chained keybinds)
keybind = ctrl+s>v=new_split:right
keybind = ctrl+s>b=new_split:down

# Closing panes and tabs
keybind = ctrl+s>x=close_surface
keybind = ctrl+s>&=close_tab

# Tab navigation
keybind = ctrl+s>l=next_tab
keybind = ctrl+s>k=previous_tab

# Reload configuration
keybind = ctrl+s>shift+r=reload_config

# ===================================================================
# Pane Navigation
# ===================================================================
# Standard split navigation (Replaces vim-tmux-navigator script)
keybind = ctrl+h=goto_split:left
keybind = ctrl+j=goto_split:bottom
keybind = ctrl+k=goto_split:top
keybind = ctrl+l=goto_split:right

{{ end }}