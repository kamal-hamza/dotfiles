{
  "layer": "top",
  "position": "top",
  "margin-top": 8,
  "margin-left": 12,
  "margin-right": 12,
  "spacing": 0,

  "modules-left": [
    "clock",
    "custom/media"
  ],
  "modules-center": [
    "hyprland/workspaces"
  ],
  "modules-right": [
    "cpu",
    "memory",
    "bluetooth",
    "network"
  ],
  "include": [
    "$HOME/.config/waybar/Modules"
  ]
}
