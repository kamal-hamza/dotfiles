[user]
	email = kamal.hamza@outlook.com
	name = kamal-hamza

[core]
	editor = nvim
	pager = delta
	autocrlf = input
	whitespace = trailing-space,space-before-tab

[init]
	defaultBranch = main

[pull]
	rebase = false

[push]
	default = simple
	autoSetupRemote = true

[fetch]
	prune = true

[merge]
	conflictstyle = diff3

[diff]
	colorMoved = default
	tool = nvimdiff

[interactive]
	diffFilter = delta --color-only

[delta]
	# Colors from Neovim palette: dot_config/nvim/colors/lua/dark/palette/dark.lua
	features = soft-focus-dark
	navigate = true    # use n and N to move between diff sections
	light = false      # set to true for light background terminals
	side-by-side = false
	line-numbers = true
	syntax-theme = base16

[delta "soft-focus-dark"]
	# Colors from Neovim palette: dot_config/nvim/colors/lua/dark/palette/dark.lua
	# Syntax highlighting
	minus-style = syntax "#ff7676"        # danger (bright red)
	minus-emph-style = syntax "#701516"   # red (dark red)
	plus-style = syntax "#86cd82"         # success (bright green)
	plus-emph-style = syntax "#14ba19"    # green (dark green)
	
	# Line numbers
	line-numbers-minus-style = "#ff7676"  # danger
	line-numbers-plus-style = "#86cd82"   # success
	line-numbers-zero-style = "#777777"   # keyword
	line-numbers-left-style = "#777777"   # keyword
	line-numbers-right-style = "#777777"  # keyword
	
	# File headers
	file-style = "#458ee6" bold           # highlight (blue)
	file-decoration-style = "#458ee6" ul  # highlight
	
	# Hunk headers
	hunk-header-style = file line-number syntax
	hunk-header-decoration-style = "#8ebeec" box  # info (bright blue)
	
	# Commit style
	commit-decoration-style = "#458ee6" box  # highlight
	commit-style = "#8ebeec" bold           # info (bright blue)
	
	# Misc
	zero-style = syntax
	whitespace-error-style = "#ff7676" reverse  # danger
	
	# Blame - using background shades
	blame-palette = "#101010" "#0a0a0a" "#272727"  # bg, bg-shade1, line
	blame-code-style = syntax
	
	# Merge conflicts
	merge-conflict-begin-symbol = ⌃
	merge-conflict-end-symbol = ⌄
	merge-conflict-ours-diff-header-style = "#d9ba73" bold           # warning (yellow)
	merge-conflict-ours-diff-header-decoration-style = "#d9ba73" box  # warning
	merge-conflict-theirs-diff-header-style = "#458ee6" bold           # highlight (blue)
	merge-conflict-theirs-diff-header-decoration-style = "#458ee6" box # highlight

[delta "soft-focus-light"]
	# Light theme variant - using same Neovim palette for consistency
	light = true
	minus-style = syntax "#ff7676"      # danger (bright red)
	minus-emph-style = syntax "#701516" # red (dark red)
	plus-style = syntax "#86cd82"       # success (bright green)
	plus-emph-style = syntax "#14ba19"  # green (dark green)
	
	line-numbers-minus-style = "#ff7676"
	line-numbers-plus-style = "#86cd82"
	line-numbers-zero-style = "#777777"
	
	file-style = "#458ee6" bold
	file-decoration-style = "#458ee6" ul
	hunk-header-decoration-style = "#8ebeec" box
	commit-decoration-style = "#458ee6" box

[color]
	ui = auto
	branch = auto
	diff = auto
	status = auto

[color "branch"]
	current = "#458ee6" bold    # highlight (blue)
	local = "#b0b0b0"           # fg
	remote = "#8ebeec"          # info (bright blue)

[color "diff"]
	meta = "#458ee6" bold       # highlight (blue)
	frag = "#8ebeec" bold       # info (bright blue)
	old = "#ff7676"             # danger (bright red)
	new = "#86cd82"             # success (bright green)
	whitespace = "#ff7676" reverse  # danger

[color "status"]
	added = "#86cd82"           # success (bright green)
	changed = "#d9ba73"         # warning (yellow)
	untracked = "#777777"       # keyword
	branch = "#458ee6" bold     # highlight (blue)
	nobranch = "#ff7676" bold   # danger (bright red)

[alias]
	# Common shortcuts
	st = status -sb
	co = checkout
	br = branch
	ci = commit
	df = diff
	dc = diff --cached
	lg = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit --date=relative
	ll = log --pretty=format:'%C(yellow)%h%Cred%d %Creset%s%Cblue [%cn]' --decorate --numstat
	ls = log --pretty=format:'%C(yellow)%h %Cred%d %Creset%s%Cblue [%cn]' --decorate
	amend = commit --amend --no-edit
	
	# Undo operations
	undo = reset --soft HEAD^
	unstage = reset HEAD --
	
	# Working with branches
	branches = branch -a
	tags = tag -l
	remotes = remote -v
	
	# Stash operations
	stash-all = stash save --include-untracked
	
	# Clean operations
	clean-merged = !git branch --merged | grep -v '\\*\\|main\\|master\\|develop' | xargs -n 1 git branch -d
	
	# Show changes
	contributors = shortlog --summary --numbered
	
	# Find commits by message
	find = log --all --oneline --grep

[url "git@github.com:"]
	insteadOf = gh:

[url "git@gitlab.com:"]
	insteadOf = gl:

[url "https://github.com/"]
	insteadOf = github:

[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
